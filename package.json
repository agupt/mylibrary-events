{
  "name": "library-storytime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "data:libraries": "node scripts/importImlsLibraries.mjs",
    "data:zips": "node scripts/importZipCodes.mjs",
    "data:import": "npm run data:libraries && npm run data:zips",
    "data:discover": "node scripts/discoverFeeds.mjs",
    "coverage": "node scripts/coverageHarness.mjs",
    "data:activate": "node scripts/activateLibcalFeeds.mjs",
    "data:verify": "node scripts/verifyDiscoveredFeeds.mjs",
    "data:domains": "node scripts/findDomains.mjs",
    "data:platforms": "node scripts/detectPlatforms.mjs",
    "data:communico": "node scripts/activateCommunicoFeeds.mjs"
  },
  "dependencies": {
    "fast-xml-parser": "^5.10.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "csv-parse": "^7.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
